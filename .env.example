# ─────────────────────────────────────────────
#  MCI Pipeline Agent — Environment Config
# ─────────────────────────────────────────────

# Slack App credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token         # Required for Socket Mode
SLACK_SIGNING_SECRET=your-signing-secret

# Channel IDs — get these from Slack (right-click channel > View channel details)
SLACK_PIPELINE_CHANNEL=C0XXXXXXXXX          # #mci-pipeline-bot
SLACK_ALERTS_CHANNEL=C0YYYYYYYYY            # #pipeline-alerts

# Anthropic API (for AI canvas Q&A)
ANTHROPIC_API_KEY=sk-ant-your-key

# MCI / Datorama API
MCI_API_BASE_URL=https://api.mci.salesforce.com/v1
MCI_API_KEY=your-mci-api-key
MCI_WORKSPACE_ID=your-workspace-id

# Optional: multiple workspaces (comma-separated)
MCI_WORKSPACE_IDS=ws-global,ws-emea,ws-apac,ws-us,ws-latam,ws-mena,ws-anz

# Morning summary schedule (cron format, default = 8:00 AM Mon-Fri)
MORNING_SUMMARY_CRON=0 8 * * 1-5
TIMEZONE=Asia/Jerusalem

# Port for HTTP server (Slack event webhooks if not using Socket Mode)
PORT=3000

# Cache TTL in seconds for pipeline stats (default = 5 minutes)
CACHE_TTL=300

# Log level: error | warn | info | debug
LOG_LEVEL=info
